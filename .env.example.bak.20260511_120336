# ═══════════════════════════════════════════════════════════════════════
# SENTINEL-AI Commander v1 — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git — it's in `.gitignore`.
#
#   cp .env.example .env
#   ./setup.sh
# ═══════════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=sentinel
DEPLOY_MODE=auto
LISTEN_ADDRESS=0.0.0.0

# ─── WAZUH CREDENTIALS ───────────────────────────────────────────────────
# These are used to bootstrap Wazuh manager/indexer/dashboard.
# Use strong passwords. The setup script will generate random ones if left empty.
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASSWORD=CHANGE_ME_STRONG_PASSWORD
WAZUH_DASHBOARD_USER=kibanaserver
WAZUH_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Cluster key — run `openssl rand -base64 32` to generate
WAZUH_CLUSTER_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# ─── LLM PROVIDERS ───────────────────────────────────────────────────────
# Groq — free tier available at https://console.groq.com
GROQ_API_KEY=CHANGE_ME_YOUR_GROQ_KEY
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# Gemini — free tier at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-2.5-flash

# Ollama — local fallback. Pulled automatically by setup.sh
OLLAMA_MODEL=llama3.2:3b
LLM_FALLBACK_ENABLED=true
PORT_OLLAMA=50060

# ─── POSTGRES ────────────────────────────────────────────────────────────
POSTGRES_HOST=sentinel-postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── REDIS ───────────────────────────────────────────────────────────────
REDIS_HOST=sentinel-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── NGINX / TLS ─────────────────────────────────────────────────────────
NGINX_HTTP_PORT=50020
NGINX_HTTPS_PORT=50021
TLS_CERT_DAYS=365
TLS_CERT_CN=sentinel-ai

# ─── AI AGENTS ───────────────────────────────────────────────────────────
AI_AGENTS_PORT=50010
# Minimum confidence threshold for Ansible auto-execute (0.0-1.0)
ANSIBLE_CONFIDENCE_THRESHOLD=0.85
# Auto-execute playbooks only for alerts with rule.level >= this
ANSIBLE_AUTO_EXECUTE_LEVEL=10
# Dry-run mode for alerts below this level (0 = run everything)
ANSIBLE_DRY_RUN_BELOW_LEVEL=7

# ─── ANSIBLE RUNNER ──────────────────────────────────────────────────────
ANSIBLE_RUNNER_HOST=sentinel-ansible-runner
ANSIBLE_RUNNER_PORT=50011

# ─── NVD (optional, for CVE lookups) ─────────────────────────────────────
# Free API key: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=CHANGE_ME_OR_LEAVE_EMPTY
NVD_API_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0

# ─── SURICATA ────────────────────────────────────────────────────────────
SURICATA_MODE=file
SURICATA_EVE_PATH=/var/log/suricata/eve.json
SURICATA_INTERFACE=eth0

# ─── PORT MAP (all in 50000-59999 range to avoid conflicts) ─────────────
PORT_WAZUH_DASHBOARD=50000
PORT_WAZUH_API=50001
PORT_WAZUH_INDEXER=50002
PORT_WAZUH_AGENT_ENROLL=50042
PORT_WAZUH_AGENT_COMM_TCP=50041
PORT_WAZUH_AGENT_COMM_UDP=50040
PORT_WAZUH_SYSLOG=50050
PORT_AI_AGENTS=50010
PORT_ANSIBLE_RUNNER=50011
PORT_REDIS=50030
PORT_POSTGRES=50031
PORT_NGINX_HTTP=50020
PORT_NGINX_HTTPS=50021

# ─── ML ──────────────────────────────────────────────────────────────────
ML_ANOMALY_CONTAMINATION=0.05

# ─── NETWORK DISCOVERY ───────────────────────────────────────────────────
# CIDR range(s) your agents live on, comma-separated
DISCOVERY_NETWORKS=192.168.1.0/24
DISCOVERY_ENABLED=true
DISCOVERY_INTERVAL_SECONDS=300
DISCOVERY_AUTO_ENROLL=false
DISCOVERY_SSH_KEY=/ansible/keys/id_rsa
DISCOVERY_SSH_USER=root
# IPs to never try to enroll (router, gateway, etc.)
DISCOVERY_EXCLUDE_IPS=192.168.1.1

# ─── WAZUH MANAGER EXTERNAL IP ───────────────────────────────────────────
# The IP agents will use to reach the manager. Usually this host's IP on the
# LAN. The setup script will try to auto-detect if left empty.
WAZUH_MANAGER_EXTERNAL_IP=

# ─── WEBHOOK (optional, for SOC notifications) ──────────────────────────
# POST incident data to this URL whenever a playbook runs.
# Leave empty to disable.
SENTINEL_WEBHOOK_URL=
