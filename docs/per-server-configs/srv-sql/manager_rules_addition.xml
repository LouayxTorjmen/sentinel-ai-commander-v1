<!--
  SENTINEL-AI Manager Rules — srv-sql (agent 015) additions
  Append to ~/sentinel-ai-commander/wazuh/config/manager/local_rules.xml

  Sections:
    1. ANOTHER FIX for rule 100131 — scope it to srv-dns-bind only
    2. Noise suppression for srv-sql agent
    3. MySQL/DB-specific high-value rules
    4. Cross-source correlation rules for DB attacks
-->

<!-- ─── FIX: rule 100131 was firing on srv-sql ─────────────────────
     The previous attempt overwrote the rule but did NOT scope it.
     Result: any agent that experiences a FIM event resembling
     a zone file + sudo within 60s gets the alert. Wrong.

     Scope to srv-dns-bind only via hostname constraint on one of
     the child rules. The cleaner way is to scope rule 100121 itself,
     but that already has the constraint. The problem must be that
     <hostname> doesn't propagate through if_matched_sid.

     Tightest fix: split into two rules. 100131 stays as the global
     correlation. 100131 fires only when BOTH children fired ON THE
     SAME AGENT — which Wazuh handles via the same_field directive.
-->

<group name="sentinel,correlation,fixes">

  <rule id="100131" level="13" frequency="2" timeframe="60" overwrite="yes">
    <if_matched_sid>100121</if_matched_sid>
    <if_sid>5402</if_sid>
    <hostname>auto-victim1-ubuntu</hostname>
    <description>Possible DNS tampering: zone file modified within 60s of sudo to root on srv-dns-bind</description>
    <mitre>
      <id>T1565.001</id>
    </mitre>
    <group>data_integrity,correlation,</group>
  </rule>

</group>

<group name="sentinel,srv-sql,noise_suppression">

  <rule id="100190" level="0">
    <if_sid>5501</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <description>PAM session opened (srv-sql: suppressed routine)</description>
  </rule>

  <rule id="100191" level="0">
    <if_sid>5502</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <description>PAM session closed (srv-sql: suppressed routine)</description>
  </rule>

  <rule id="100192" level="0">
    <if_sid>5402</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <description>Successful sudo (srv-sql: suppressed routine admin)</description>
  </rule>

</group>

<group name="sentinel,srv-sql,mysql_specific">

  <!-- MySQL config file tampering -->
  <rule id="100180" level="12">
    <if_sid>550,553,554</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <match>/etc/my.cnf</match>
    <description>MySQL config modified on srv-sql: $(file)</description>
    <mitre>
      <id>T1562</id>
    </mitre>
    <group>config_tampering,defense_evasion,</group>
  </rule>

  <!-- Per-DB cnf file tampering inside /var/lib/mysql -->
  <rule id="100181" level="11">
    <if_sid>550,553,554</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <match>/var/lib/mysql/</match>
    <match>.cnf</match>
    <description>Per-DB MySQL config modified on srv-sql: $(file)</description>
    <mitre>
      <id>T1562</id>
    </mitre>
    <group>config_tampering,defense_evasion,</group>
  </rule>

  <!-- MySQL access denied burst — possible credential brute force.
       Triggered by Wazuh's existing MySQL rules (50101, 50102 are
       in the default ruleset). frequency=5 in 60s = brute force. -->
  <rule id="100182" level="11" frequency="5" timeframe="60">
    <if_matched_sid>50101</if_matched_sid>
    <hostname>auto-victim2-rhel</hostname>
    <description>MySQL credential brute force on srv-sql: 5+ access denied in 60s</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>brute_force,authentication_failures,</group>
  </rule>

  <!-- mysqld process spawning shell-like child via Falco.
       This is the SQL injection → RCE smoking gun.
       Detects via Falco rule 100110 firing with parent process mysqld. -->
  <rule id="100183" level="14">
    <if_sid>100110</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <match>"proc.pname":"mysqld"</match>
    <match>"evt.type":"execve"</match>
    <description>mysqld spawned child process on srv-sql — possible SQL RCE</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>execution,T1190,</group>
  </rule>

  <!-- mysqld reading sensitive file outside its data dir.
       mysqld legitimately reads /var/lib/mysql/* and its own config.
       Reading /etc/shadow, /etc/passwd, SSH keys, etc = compromise. -->
  <rule id="100184" level="13">
    <if_sid>100110</if_sid>
    <hostname>auto-victim2-rhel</hostname>
    <match>"proc.name":"mysqld"</match>
    <match>"rule":"Read sensitive file</match>
    <description>mysqld reading sensitive file on srv-sql — possible compromise</description>
    <mitre>
      <id>T1003</id>
    </mitre>
    <group>credential_access,T1003,</group>
  </rule>

</group>

<group name="sentinel,correlation,srv-sql">

  <!-- DB brute force correlated with Suricata network detection of MySQL traffic.
       Rule 100182 + Suricata MySQL signature in same timeframe = coordinated. -->
  <rule id="100185" level="13" frequency="2" timeframe="60">
    <if_matched_sid>100182</if_matched_sid>
    <if_sid>86601</if_sid>
    <description>Coordinated MySQL brute force on srv-sql: app-layer + network layer agree</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>brute_force,correlation,</group>
  </rule>

  <!-- mysqld spawned shell + outbound connection within 30s = RCE → exfil -->
  <rule id="100186" level="15" frequency="2" timeframe="30">
    <if_matched_sid>100183</if_matched_sid>
    <if_matched_sid>100110</if_matched_sid>
    <description>POSSIBLE SQL RCE + EXFIL on srv-sql: mysqld shell + outbound</description>
    <mitre>
      <id>T1071.001</id>
    </mitre>
    <group>command_and_control,exfiltration,correlation,</group>
  </rule>

</group>
