<!-- SENTINEL-AI Custom Decoders -->

<!-- Suricata eve.json -->
<decoder name="suricata-eve">
  <prematch>^{"timestamp"</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!-- BIND9 query log
     Format: DD-Mon-YYYY HH:MM:SS.mmm queries: client @0xADDR src#port (name): query: name IN type flags (server)
     Example: 16-May-2026 16:30:00.123 queries: client @0xABC 10.70.0.10#54321 (foo.com): query: foo.com IN A +E(0)K (10.50.0.11) -->
<decoder name="bind9-query">
  <prematch>queries: client</prematch>
  <regex>queries: client \S+ (\d+.\d+.\d+.\d+)#\d+ \(\S+\): query: (\S+) IN (\S+)</regex>
  <order>srcip,query_name,query_type</order>
</decoder>

<!-- dnsdist DoH JSON log -->
<decoder name="dnsdist-doh">
  <prematch>^{"timestamp"</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>

<!-- nginx TLS access log — weak cipher detection on srv-web
     Format: $remote_addr - - [$time_local] "$request" $status $bytes ssl_protocol=$ssl_protocol ssl_cipher=$ssl_cipher
     Example: 10.60.0.10 - - [30/May/2026:18:02:34 +0100] "GET / HTTP/1.1" 200 155 ssl_protocol=TLSv1.2 ssl_cipher=AES128-SHA -->
<decoder name="nginx-sentinel-tls">
  <prematch>^SENTINEL_TLS </prematch>
  <regex>^SENTINEL_TLS (\.+) proto=(\.+) cipher=(\.+) status=</regex>
  <order>srcip,tls_protocol,tls_cipher</order>
</decoder>

<!-- MySQL general query log — credential theft detection -->
<decoder name="mysql-general-log">
  <prematch>mysql-audit </prematch>
  <regex>mysql-audit \.+ Query\s+(\.+)$</regex>
  <order>mysql_query</order>
</decoder>

<decoder name="mysql-general-log-connect">
  <prematch>mysql-audit </prematch>
  <regex>mysql-audit \.+ Connect\s+\S+@(\d+\.\d+\.\d+\.\d+) </regex>
  <order>srcip</order>
</decoder>
