<!-- SENTINEL-AI Custom Rules -->
<group name="local,syslog,suricata,sentinel">

  <!-- ── Suricata IDS alerts via eve.json ──────────────────────────────── -->
  <rule id="100001" level="5">
    <decoded_as>json</decoded_as>
    <field name="event_type">^alert$</field>
    <description>Suricata IDS: $(alert.signature)</description>
    <group>ids,suricata,</group>
  </rule>

  <rule id="100002" level="8">
    <if_sid>100001</if_sid>
    <field name="alert.severity">1</field>
    <description>Suricata IDS CRITICAL: $(alert.signature)</description>
    <group>ids,suricata,attack,</group>
  </rule>

  <rule id="100003" level="7">
    <if_sid>100001</if_sid>
    <field name="alert.severity">2</field>
    <description>Suricata IDS HIGH: $(alert.signature)</description>
    <group>ids,suricata,attack,</group>
  </rule>

  <!-- ── SSH brute force escalation ────────────────────────────────────── -->
  <rule id="100010" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5716</if_matched_sid>
    <description>SSH brute force attack (8+ failures in 2 min) from $(srcip)</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,brute_force,</group>
  </rule>

  <!-- ── Successful login after brute force ────────────────────────────── -->
  <rule id="100011" level="12">
    <if_matched_sid>100010</if_matched_sid>
    <if_sid>5715</if_sid>
    <same_source_ip/>
    <description>Successful login after brute force from $(srcip) — possible credential compromise</description>
    <mitre>
      <id>T1078</id>
    </mitre>
    <group>authentication_success,brute_force,credential_access,</group>
  </rule>

  <!-- ── Web attack patterns ───────────────────────────────────────────── -->
  <rule id="100020" level="10">
    <if_sid>31100</if_sid>
    <url>../</url>
    <description>Directory traversal attempt from $(srcip)</description>
    <mitre>
      <id>T1083</id>
    </mitre>
    <group>web,attack,</group>
  </rule>

</group>
