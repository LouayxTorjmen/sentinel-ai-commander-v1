# =============================================================================
#  SENTINEL-AI Custom Suricata Rules — MITRE ATT&CK Mapped
# =============================================================================

# ── T1110.001 — SSH Brute Force ──────────────────────────────────────────────
alert ssh any any -> $HOME_NET 22 (msg:"SENTINEL SSH brute force attempt"; \
    flow:to_server,established; threshold:type both, track by_src, count 5, seconds 60; \
    classtype:attempted-admin; sid:9000001; rev:1; \
    metadata:mitre_technique_id T1110.001, mitre_technique_name "Brute Force - Password Guessing";)

# ── T1046 — Network Service Scanning (Port Scan) ────────────────────────────
alert tcp any any -> $HOME_NET any (msg:"SENTINEL TCP port scan detected"; \
    flags:S; threshold:type both, track by_src, count 20, seconds 10; \
    classtype:attempted-recon; sid:9000002; rev:1; \
    metadata:mitre_technique_id T1046, mitre_technique_name "Network Service Discovery";)

# ── T1190 — Exploit Public-Facing Application (SQL Injection) ────────────────
alert http any any -> $HOME_NET any (msg:"SENTINEL SQL injection attempt"; \
    flow:to_server,established; content:"SELECT"; nocase; http_uri; \
    pcre:"/(\%27)|(\')|(\-\-)|(\%23)|(#)/i"; \
    classtype:web-application-attack; sid:9000003; rev:1; \
    metadata:mitre_technique_id T1190, mitre_technique_name "Exploit Public-Facing Application";)

# ── T1071.001 — Application Layer Protocol (Suspicious HTTP) ────────────────
alert http any any -> $EXTERNAL_NET any (msg:"SENTINEL suspicious HTTP user-agent (curl/wget)"; \
    flow:to_server,established; content:"curl"; http_user_agent; nocase; \
    classtype:policy-violation; sid:9000004; rev:1; \
    metadata:mitre_technique_id T1071.001, mitre_technique_name "Web Protocols";)

# ── T1071.004 — DNS Tunneling Indicator ──────────────────────────────────────
alert dns any any -> any any (msg:"SENTINEL possible DNS tunneling - long query"; \
    dns.query; content:"|00|"; offset:0; pcre:"/^.{60,}/"; \
    classtype:bad-unknown; sid:9000005; rev:1; \
    metadata:mitre_technique_id T1071.004, mitre_technique_name "DNS";)

# ── T1048.003 — Exfiltration Over Unencrypted Protocol ──────────────────────
alert tcp $HOME_NET any -> $EXTERNAL_NET 21 (msg:"SENTINEL FTP outbound data transfer"; \
    flow:to_server,established; content:"STOR"; nocase; \
    classtype:policy-violation; sid:9000006; rev:1; \
    metadata:mitre_technique_id T1048.003, mitre_technique_name "Exfiltration Over Unencrypted Non-C2 Protocol";)

# ── T1059.004 — Command and Scripting - Unix Shell ──────────────────────────
alert http any any -> $HOME_NET any (msg:"SENTINEL shell command injection via HTTP"; \
    flow:to_server,established; content:"/bin/"; http_uri; \
    classtype:web-application-attack; sid:9000007; rev:1; \
    metadata:mitre_technique_id T1059.004, mitre_technique_name "Unix Shell";)

# ── T1105 — Ingress Tool Transfer ───────────────────────────────────────────
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"SENTINEL possible tool download (ELF binary)"; \
    flow:to_server,established; content:"GET"; http_method; \
    content:".elf"; http_uri; nocase; \
    classtype:policy-violation; sid:9000008; rev:1; \
    metadata:mitre_technique_id T1105, mitre_technique_name "Ingress Tool Transfer";)

# ── T1595.002 — Active Scanning (Vulnerability Scanning) ────────────────────
alert http any any -> $HOME_NET any (msg:"SENTINEL vulnerability scanner detected (Nmap/Nikto)"; \
    flow:to_server,established; pcre:"/Nmap|Nikto|Nessus|OpenVAS|sqlmap/iH"; \
    classtype:attempted-recon; sid:9000009; rev:1; \
    metadata:mitre_technique_id T1595.002, mitre_technique_name "Vulnerability Scanning";)

# ── T1021.001 — Remote Services: RDP ────────────────────────────────────────
alert tcp any any -> $HOME_NET 3389 (msg:"SENTINEL RDP connection attempt from external"; \
    flags:S; classtype:attempted-admin; sid:9000010; rev:1; \
    metadata:mitre_technique_id T1021.001, mitre_technique_name "Remote Desktop Protocol";)
